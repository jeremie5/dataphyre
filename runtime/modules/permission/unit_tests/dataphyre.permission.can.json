        "function": "can",
        "class": "dataphyre\\permission",
        "static_method": true,
        "args": [
            {
                "permissions": ["panel.orders.*", "-panel.orders.force_delete"]
            },
            "panel.orders.force_delete"
        ],
        "expected": false,
        "file_dynamic": "return dp_module_present(\"permission\")[0];",
        "max_millis": 50
    },
    {
        "name": "child_exists_matches_any_positive_child",
        "function": "can",
        "class": "dataphyre\\permission",
        "static_method": true,
        "args": [
            {
                "permissions": ["inventory.products.view", "-inventory.products.delete"]
            },
            "inventory.products.%"
