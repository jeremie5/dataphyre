        "expected": true,
        "file_dynamic": "return dp_module_present(\"permission\")[0];",
        "max_millis": 50
    },
    {
        "name": "strict_check_ignores_parent_inference",
        "function": "can",
        "class": "dataphyre\\permission",
        "static_method": true,
        "args": [
            {
                "permissions": ["inventory.products.view"]
