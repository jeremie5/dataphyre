    {
        "name": "semantic_wildcard_allows_child",
        "function": "can",
        "class": "dataphyre\\permission",
        "static_method": true,
        "args": [
            {
                "permissions": ["panel.orders.*"]
            },
            "panel.orders.update"
        ],
        "expected": true,
        "file_dynamic": "return dp_module_present(\"permission\")[0];",
        "max_millis": 50
    },
    {
