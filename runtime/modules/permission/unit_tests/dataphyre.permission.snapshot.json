[
    {
        "name": "snapshot_captures_allowed_and_denied_permissions",
        "function": "snapshot",
        "class": "dataphyre\\permission",
        "static_method": true,
        "args": [
            {
                "permissions": ["panel.orders.view_any"]
            },
            ["panel.orders.view_any", "panel.orders.update"]
        ],
        "expected": {
            "custom_script": "return is_array($result) && in_array('panel.orders.view_any', $result['allowed'] ?? [], true) && in_array('panel.orders.update', $result['denied'] ?? [], true);"
        },
        "file_dynamic": "return dp_module_present(\"permission\")[0];",
        "max_millis": 50
    },
    {
        "name": "diff_snapshots_reports_effective_grants",
        "function": "diffSnapshots",
        "class": "dataphyre\\permission",
        "static_method": true,
        "args": [
            {
                "decisions": {
                    "panel.orders.view_any": true,
                    "panel.orders.update": false
                },
                "roles": [],
                "rules": ["panel.orders.view_any"]
            },
            {
                "decisions": {
                    "panel.orders.view_any": true,
                    "panel.orders.update": true
                },
                "roles": [],
                "rules": ["panel.orders.*"]
            }
        ],
        "expected": {
            "custom_script": "return is_array($result) && ($result['ok'] ?? null) === false && in_array('panel.orders.update', $result['granted'] ?? [], true) && in_array('panel.orders.*', $result['rule_changes']['added'] ?? [], true);"
        },
        "file_dynamic": "return dp_module_present(\"permission\")[0];",
        "max_millis": 50
    }
]
